# --- REGLAS GENERALES ---
node_modules/
dist/
dist-ssr/
vendor/
backend_ofiliaria/.env*
.env
.env.*
!.env.example
*.log
.vscode/
.idea
.DS_Store

# --- FILTROS DE COPIAS Y ORIGINALES ---
# Ignora cualquier archivo o carpeta que contenga estas palabras
*copia*
*copy*
*original*

# --- CARPETAS PERSONALES / RESPALDOS ---
/documentacion/
/chat_gemini/
/respaldo-wordpress/

# --- REGLAS LARAVEL (backend_ofiliaria) ---
/backend_ofiliaria/storage/*.key
/backend_ofiliaria/public/storage
/backend_ofiliaria/public/build
/backend_ofiliaria/public/hot
/backend_ofiliaria/.phpunit.result.cache

# Bloquea cualquier archivo que contenga .env en cualquier parte del nombre
**/.env*

# --- REGLAS WORDPRESS (redetron) ---
# 1. Ignoramos TODO lo que esté dentro de la carpeta wordpress
/redetron/*

# 2. Permitimos entrar a wp-content (pero no sus archivos)
!/redetron/wp-content/

# 3. Permitimos entrar a themes y plugins (pero no su contenido aún)
!/redetron/wp-content/themes/
!/redetron/wp-content/plugins/

# 4. Bloqueamos todas las carpetas dentro de themes y plugins primero
/redetron/wp-content/themes/*
/redetron/wp-content/plugins/*

# 5. AHORA SÍ: Permitimos EXCLUSIVAMENTE tus carpetas de desarrollo
!/redetron/wp-content/themes/wpresidence-child/
!/redetron/wp-content/plugins/ofiliaria/

# --- REGLAS INTERNAS DEL PLUGIN ---
/redetron/wp-content/plugins/ofiliaria/**/node_modules/
/redetron/wp-content/plugins/ofiliaria/**/dist/
/redetron/wp-content/plugins/ofiliaria/**/*.local

# Reglas específicas para asegurar el bloqueo
backend_ofiliaria/.env_produccion
backend_ofiliaria/.env_gemini